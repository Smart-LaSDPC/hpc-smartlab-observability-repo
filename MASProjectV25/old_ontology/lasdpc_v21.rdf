    </owl:DatatypeProperty>
    


    <!-- http://www.icmc.usp.br/smartlasdpc#temp_value -->

    <owl:DatatypeProperty rdf:about="http://www.icmc.usp.br/smartlasdpc#temp_value">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.icmc.usp.br/smartlasdpc#temp_value"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


