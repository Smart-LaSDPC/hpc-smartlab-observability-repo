    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.example.com.br/demo#askForService -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#askForService">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#User"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#BasicService"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#contain -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#contain">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#DataCenter"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#Rack"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#installedIn -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#installedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#Device"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#Room"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#locatedIn -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#locatedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#DataCenter"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#Room"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#matriculatedIn -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#matriculatedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#StudentUnderground"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#ActivityUnder"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#participateIn -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#participateIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.example.com.br/demo#User"/>
        <rdfs:range rdf:resource="http://www.example.com.br/demo#Laboratory"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.com.br/demo#studyingIn -->

    <owl:ObjectProperty rdf:about="http://www.example.com.br/demo#studyingIn">
