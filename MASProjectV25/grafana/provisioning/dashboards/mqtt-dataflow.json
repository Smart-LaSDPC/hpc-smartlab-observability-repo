{
  "title": "MQTT Data Flow",
  "uid": "mas-mqtt",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "MQTT Sensor Messages (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(mas_mqtt_messages_received_total{topic_type=\"sensor\"}[1m]) * 60",
          "legendFormat": "sensor msgs/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "MQTT Asset Messages (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(mas_mqtt_messages_received_total{topic_type=\"asset\"}[1m]) * 60",
          "legendFormat": "asset msgs/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Total MQTT Messages (all time)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(mas_mqtt_messages_received_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "MQTT Commands Published by Type",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "mas_control_mqtt_commands_published_total",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "DeviceData Batches Sent (total)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "mas_collector_device_data_sent_total",
          "legendFormat": "batches",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Ontology State Changes (rate/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "rate(mas_control_ontology_changes_detected_total[1m]) * 60",
          "legendFormat": "state changes/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
