{
  "title": "JVM & System Resources",
  "uid": "mas-jvm",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{area=\"heap\"}",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_bytes_max{area=\"heap\"}",
          "legendFormat": "heap max",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 2,
      "title": "JVM Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_bytes_used{area=\"nonheap\"}",
          "legendFormat": "nonheap used",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "title": "JVM Thread Count",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "jvm_threads_current",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon",
          "legendFormat": "daemon",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "GC Collection Time (rate/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_seconds_sum[1m])",
          "legendFormat": "{{gc}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "process_cpu_seconds_total",
          "legendFormat": "cpu seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Process Open File Descriptors",
      "type": "stat",
      "gridPos": { "x": 12, "y": 15, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "open fds",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Process Uptime",
      "type": "stat",
      "gridPos": { "x": 18, "y": 15, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "process_start_time_seconds",
          "legendFormat": "start time",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } }
    }
  ]
}
